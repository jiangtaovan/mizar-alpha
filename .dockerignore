# ============================================================
# Mizar Docker 忽略文件
# ============================================================
# 说明：
#   - 此文件位于项目根目录，与 Dockerfile 同级。
#   - 匹配规则类似 .gitignore，但语法略有差异（无 ! 取反）。
#   - 目的是排除构建时不需要的文件/目录，减小镜像体积并保护隐私。
# ============================================================

# --------------------------------------
# Python 运行时生成文件
# --------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
*.pem

# --------------------------------------
# 虚拟环境
# --------------------------------------
venv/
env/
.env/
.venv/
virtualenv/
*.env.local
*.env.*.local

# --------------------------------------
# IDE 与编辑器配置
# --------------------------------------
.vscode/
../.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --------------------------------------
# 版本控制
# --------------------------------------
.git/
.gitignore
.gitattributes
.gitmodules

# --------------------------------------
# 文档与示例（若需要可保留）
# --------------------------------------
docs/
*.md
!README.md
!QUICKSTART.md
LICENSE

# --------------------------------------
# 测试与开发工具
# --------------------------------------
tests/
*.test.py
*.spec.js
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
benchmark/
mizar/alcor

# --------------------------------------
# 数据文件（运行时通过卷挂载）
# --------------------------------------
datas/
*.csv
*.json
!config/*.yaml
!config/*.json

# --------------------------------------
# 向量库与模型存储（运行时通过卷挂载）
# --------------------------------------
storage/
models/
logs/
*.db
*.sqlite
*.sqlite3

# --------------------------------------
# 临时与备份文件
# --------------------------------------
*.bak
*.tmp
*.temp
*.log
*.pid
*.seed
*.pid.lock

# --------------------------------------
# 配置文件中的敏感信息（保留模板）
# --------------------------------------
.env
.env.*
!.env.example

# --------------------------------------
# 脚本与工具（仅保留必要的入口）
# --------------------------------------
scripts/
!docker-entrypoint.sh

# --------------------------------------
# Jupyter Notebook
# --------------------------------------
.ipynb_checkpoints/
*.ipynb

# --------------------------------------
# macOS 特有文件
# --------------------------------------
.AppleDouble
.LSOverride
._*

# --------------------------------------
# Windows 特有文件
# --------------------------------------
desktop.ini